# Server
PORT=3000
NODE_ENV=development

# Auth — change JWT_SECRET to a long random string before deploying.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_IN=1d

# PostgreSQL — only needed if you switch from the in-memory store to a real database.
# See src/database/connection.js for the pool setup.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=appdb
DB_USER=postgres
DB_PASSWORD=postgres

# CORS — set to your frontend's origin in production.
# Use * to allow all origins in development (not recommended in production).
CORS_ORIGIN=http://localhost:3000
