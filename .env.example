# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=appdb
DB_USER=postgres
DB_PASSWORD=postgres

# ── AWS / LocalStack ──────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# LocalStack endpoint — leave blank when targeting real AWS
SNS_ENDPOINT=http://localhost:4566
SQS_ENDPOINT=http://localhost:4566

# ── SNS ───────────────────────────────────────────────────────
# Name used when creating the topic (init-aws.sh reads this).
SNS_TOPIC_NAME=application-events
# Full ARN — set automatically by LocalStack; in production use your real ARN.
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:application-events

# ── SQS ───────────────────────────────────────────────────────
# Queue names — must match what the Lambda event-source mapping uses.
SQS_QUEUE_NAME=salesforce-integration-queue
SQS_DLQ_NAME=salesforce-integration-dlq
# How long (seconds) a message is hidden while Lambda is processing it.
# Must be >= LAMBDA_TIMEOUT. Increase if Lambda needs more processing time.
SQS_VISIBILITY_TIMEOUT=30
# How many times a message can fail before it is moved to the DLQ.
SQS_MAX_RECEIVE_COUNT=3

# ── Worker (Outbox publisher) ─────────────────────────────────
# How often the worker polls for unpublished events (milliseconds).
# Lower = faster delivery but more DB queries.
POLL_INTERVAL_MS=5000
# How many outbox_events rows to fetch and publish per poll cycle.
BATCH_SIZE=10

# ── Lambda ────────────────────────────────────────────────────
LAMBDA_FUNCTION_NAME=salesforce-integration-consumer
# Lambda execution timeout in seconds. SQS_VISIBILITY_TIMEOUT must be >= this.
LAMBDA_TIMEOUT=30
# Number of SQS messages Lambda receives per invocation (1–10000).
LAMBDA_BATCH_SIZE=5

# ── Salesforce (Lambda env vars) ─────────────────────────────
SALESFORCE_INSTANCE_URL=https://your-instance.my.salesforce.com
SALESFORCE_CLIENT_ID=your-connected-app-client-id
SALESFORCE_CLIENT_SECRET=your-connected-app-client-secret
# Override only if using sandbox: https://test.salesforce.com/services/oauth2/token
SALESFORCE_TOKEN_URL=https://login.salesforce.com/services/oauth2/token
