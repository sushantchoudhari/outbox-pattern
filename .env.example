# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=appdb
DB_USER=postgres
DB_PASSWORD=postgres

# ── AWS / LocalStack ──────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# LocalStack endpoint — leave blank when targeting real AWS
SNS_ENDPOINT=http://localhost:4566
SQS_ENDPOINT=http://localhost:4566

# Resolved by LocalStack init script; matches the ARN format LocalStack uses
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:application-events

# ── Worker ────────────────────────────────────────────────────
POLL_INTERVAL_MS=5000
BATCH_SIZE=10

# ── Salesforce (Lambda) ───────────────────────────────────────
SALESFORCE_INSTANCE_URL=https://your-instance.my.salesforce.com
SALESFORCE_CLIENT_ID=your-connected-app-client-id
SALESFORCE_CLIENT_SECRET=your-connected-app-client-secret
# Override only if using sandbox: https://test.salesforce.com/services/oauth2/token
SALESFORCE_TOKEN_URL=https://login.salesforce.com/services/oauth2/token
