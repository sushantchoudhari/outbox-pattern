# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=1d

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Logging ──────────────────────────────────────────────────────────────────
# Levels: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
# Leave empty to use the in-memory store (no database required to run).
DATABASE_URL=
# ─── Redis (session store) ──────────────────────────────────────────────────────────
# Local: redis://localhost:6379  (start with: docker compose up redis)
# Production: redis://<elasticache-endpoint>.cache.amazonaws.com:6379
#             rediss://  (note the extra 's') for TLS-enabled ElastiCache
REDIS_URL=redis://localhost:6379

# ─── Session ────────────────────────────────────────────────────────────────────────────
# Used to sign the session cookie. Changing this invalidates all existing sessions.
# Must be at least 32 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-this-with-a-long-random-secret-min-32-chars
# Session and cookie TTL in milliseconds.  Default: 86400000 (24 hours).
SESSION_MAX_AGE_MS=86400000