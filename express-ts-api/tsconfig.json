{
  "compilerOptions": {
    "target":                        "ES2022",
    "module":                        "CommonJS",
    "lib":                           ["ES2022"],
    "strict":                        true,
    "noImplicitOverride":            true,
    "esModuleInterop":               true,
    "skipLibCheck":                  true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule":             true,
    "sourceMap":                     true
  },
  "include": ["src/**/*", "tests/**/*", "jest.config.ts"],
  "exclude": ["node_modules", "dist"]
}
